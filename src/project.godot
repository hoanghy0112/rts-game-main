; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RTS Game"
run/main_scene="res://modules/loading/boot.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
run/max_fps=300
config/icon="res://icon.svg"

[autoload]

SettingsManager="*res://globals/settings_manager.gd"
StartupPerformanceProbe="*res://globals/startup_performance_probe.gd"

[display]

window/size/mode=3
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="RTS Game"

[editor_plugins]

enabled=PackedStringArray("res://addons/terrain_3d/plugin.cfg", "res://addons/village_brush/plugin.cfg", "res://addons/waterways/plugin.cfg", "res://addons/forest_brush/plugin.cfg")

